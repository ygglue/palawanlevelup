---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---
<Layout title="Palawan Level Up — Landing Pages & Automations" description="Palawan Level Up builds Go High Level landing pages and automations that convert.">
  <Nav />
  <main>
    <section id="top">
      <h1 style="font-family: 'Instrument Serif', serif; font-size: clamp(3rem, 8vw, 7rem);">Palawan Level Up</h1>
    </section>
    <section id="services" class="min-h-screen">Services placeholder</section>
    <section id="work" class="min-h-screen">Work placeholder</section>
    <section id="process" class="min-h-screen">Process placeholder</section>
    <section id="about" class="min-h-screen">About placeholder</section>
    <section id="contact" class="min-h-screen">Contact placeholder</section>
  </main>
</Layout>
